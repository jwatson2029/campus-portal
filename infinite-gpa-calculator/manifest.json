{
  "manifest_version": 3,
  "name": "Studently",
  "version": "1.0.0",
  "description": "Instantly calculate Unweighted & Weighted GPA from Infinite Campus grades — with per-course breakdown, export, and custom weighting.",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "host_permissions": [
    "https://campus.forsyth.k12.ga.us/*",
    "https://*.infinitecampus.org/*",
    "https://*.infinitecampus.com/*"
  ],

  "action": {
    "default_title": "Studently",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://campus.forsyth.k12.ga.us/*",
        "https://*.infinitecampus.org/*",
        "https://*.infinitecampus.com/*"
      ],
      "js": ["inject-button.js", "content.js"],
      "css": ["modal.css"],
      "run_at": "document_idle"
    }
  ],

  "commands": {
    "open-gpa-calculator": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "Toggle Studently (GPA & what-if)"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["modal.css", "inject-button.js", "icons/*.png"],
      "matches": [
        "https://campus.forsyth.k12.ga.us/*",
        "https://*.infinitecampus.org/*",
        "https://*.infinitecampus.com/*"
      ]
    }
  ]
}
