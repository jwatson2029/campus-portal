{
  "manifest_version": 3,
  "name": "Infinite GPA Calculator",
  "version": "1.0.0",
  "description": "Instantly calculate your Unweighted & Weighted GPA from your Infinite Campus grades — with per-course breakdown, export, and customizable weighting.",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "permissions": ["storage", "scripting"],

  "host_permissions": [
    "https://campus.forsyth.k12.ga.us/*",
    "https://*.infinitecampus.org/*",
    "https://*.infinitecampus.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://campus.forsyth.k12.ga.us/*",
        "https://*.infinitecampus.org/*",
        "https://*.infinitecampus.com/*"
      ],
      "js": ["inject-button.js", "content.js"],
      "css": ["modal.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "options_page": "options.html",

  "commands": {
    "open-gpa-calculator": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "Open the GPA Calculator"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["modal.html", "modal.js", "modal.css", "inject-button.js", "icons/*.png"],
      "matches": [
        "https://campus.forsyth.k12.ga.us/*",
        "https://*.infinitecampus.org/*",
        "https://*.infinitecampus.com/*"
      ]
    }
  ]
}
